FRAMEWORK_GIT_URL=https://github.com/stashfin2/pw-api-framework.git
FRAMEWORK_BRANCH=main
FRAMEWORK_WORKSPACE_DIR=./workspace/framework
FRAMEWORK_GIT_TOKEN=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
FRAMEWORK_REFRESH_ON_START=false

PORT=3000
HOST=0.0.0.0

# --- LLM (steps 5g + 12 only; rest of pipeline stays deterministic) ---
# Pick provider: gemini | openai | heuristic
LLM_PROVIDER=gemini

# Paste your Gemini key here (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSyCMZ6GJWTHw8eCRqBIb4v8pxr0Blxn3lQ8
# Per-model quota: 2.0-flash exhausted → use 2.5-flash-lite (separate free-tier bucket)
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional fallbacks if primary hits 429 (comma-separated)
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-1.5-flash

# Continue run when Gemini quota/rate-limit fails (smoke specs still generated)
LLM_FAIL_OPEN=true

# Single generic LLM prompt: agent-knowledge/prompts/llm.system.txt
# LLM_PROMPTS_DIR=./agent-knowledge/prompts

# Or use OpenAI instead — set LLM_PROVIDER=openai and paste key below
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
