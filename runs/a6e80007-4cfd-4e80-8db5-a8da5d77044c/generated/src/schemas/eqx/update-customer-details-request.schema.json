{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "PUT /update-customer-details request body",
  "type": "object",
  "required": [
    "device_id",
    "first_name",
    "last_name"
  ],
  "properties": {
    "device_id": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "lead_source": {
      "type": "string"
    },
    "pull_type": {
      "type": "string",
      "enum": [
        "short_pull",
        "long_pull"
      ]
    }
  }
}
